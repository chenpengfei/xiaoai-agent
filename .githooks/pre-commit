#!/bin/sh
set -eu

if [ "${SKIP_GIT_GUARDS:-}" = "1" ]; then
  exit 0
fi

max_bytes=$((10 * 1024 * 1024))
fail=0
fail_file=$(mktemp "${TMPDIR:-/tmp}/xiaoai-pre-commit.XXXXXX")
trap 'rm -f "$fail_file"' EXIT
secret_regex='(AKIA[0-9A-Z]{16}|sk-[A-Za-z0-9_-]{20,}|xox[baprs]-[A-Za-z0-9-]{20,}|-----BEGIN [A-Z ]*PRIVATE KEY-----)'

staged_paths=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$staged_paths" ]; then
  exit 0
fi

echo "$staged_paths" | while IFS= read -r path; do
  [ -n "$path" ] || continue

  if git check-ignore -q -- "$path"; then
    printf 'pre-commit: ignored file is staged: %s\n' "$path" >&2
    echo 1 >> "$fail_file"
  fi

  case "$path" in
    .DS_Store|*/.DS_Store|*__pycache__*|*.pyc|*.pyo|*.pyd)
      printf 'pre-commit: cache or OS artifact is staged: %s\n' "$path" >&2
      echo 1 >> "$fail_file"
      ;;
    audio-samples/*|voice-gateway/audio-samples/*|logs/*|*/logs/*|firmware/*|fw-inspect/*)
      printf 'pre-commit: generated/local artifact path is staged: %s\n' "$path" >&2
      echo 1 >> "$fail_file"
      ;;
    .env|*/.env|.env.*|*/.env.*)
      case "$path" in
        .env.example|*/.env.example) ;;
        *)
          printf 'pre-commit: environment file is staged: %s\n' "$path" >&2
          echo 1 >> "$fail_file"
          ;;
      esac
      ;;
    *.pem|*.key|*.p12|*.pfx|id_rsa|*/id_rsa|id_ed25519|*/id_ed25519)
      printf 'pre-commit: private key or certificate-like file is staged: %s\n' "$path" >&2
      echo 1 >> "$fail_file"
      ;;
  esac

  size=$(git cat-file -s ":$path" 2>/dev/null || printf '0')
  if [ "$size" -gt "$max_bytes" ]; then
    if ! git show ":$path" | head -c 80 | grep -q 'version https://git-lfs.github.com/spec/v1'; then
      printf 'pre-commit: large file is staged without Git LFS pointer: %s (%s bytes)\n' "$path" "$size" >&2
      echo 1 >> "$fail_file"
    fi
  fi

  if git show ":$path" 2>/dev/null | LC_ALL=C grep -I -E "$secret_regex" >/dev/null; then
    printf 'pre-commit: possible secret detected in staged content: %s\n' "$path" >&2
    echo 1 >> "$fail_file"
  fi
done

if [ -s "$fail_file" ]; then
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  cat >&2 <<'EOF'

Commit blocked by local repository guards.
Move generated files out of the index, use Git LFS for intentional large files,
or set SKIP_GIT_GUARDS=1 only for a deliberate emergency bypass.
EOF
  exit 1
fi
