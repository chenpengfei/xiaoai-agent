#!/bin/sh
set -eu

msg_file=${1:?missing commit message file}
first_line=$(sed -n '1p' "$msg_file")

case "$first_line" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9][a-z0-9._-]*\))?!?: .{1,72}$'

if printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
Invalid commit message.

Use Conventional Commits:
  feat(scope): add local voice trigger
  fix: handle reconnect timeout
  docs: update validation runbook
  chore!: drop deprecated runtime flag

Allowed types:
  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert

Rules:
  - format: type(optional-scope)!: subject
  - scope: lowercase letters, numbers, dot, underscore, or hyphen
  - subject: 1-72 characters
EOF

exit 1
